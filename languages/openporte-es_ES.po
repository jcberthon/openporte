#. Plugin Name of the plugin
#: openporte.php
#: includes/admin.php:15
msgid "OpenPorte Spam Protection"
msgstr "OpenPorte Spam Protection"

#. Description of the plugin
#: openporte.php
msgid "OpenPorte is a free, open-source CAPTCHA alternative that offers robust spam and bot protection without using cookies, ensuring full GDPR compliance by design. A community-maintained fork of the ALTCHA Spam Protection plugin (v1)."
msgstr "OpenPorte es una alternativa gratuita y de código abierto a CAPTCHA que ofrece robusta protección contra spam y bots sin usar cookies, garantizando el cumplimiento total del GDPR por diseño. Un fork mantenido por la comunidad del plugin ALTCHA Spam Protection (v1)."

