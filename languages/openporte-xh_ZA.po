#. Plugin Name of the plugin
#: openporte.php
#: includes/admin.php:15
msgid "OpenPorte Spam Protection"
msgstr "OpenPorte Spam Protection"

#. Description of the plugin
#: openporte.php
msgid "OpenPorte is a free, open-source CAPTCHA alternative that offers robust spam and bot protection without using cookies, ensuring full GDPR compliance by design. A community-maintained fork of the ALTCHA Spam Protection plugin (v1)."
msgstr "OpenPorte yincundlela entsi free, evulelekileyo ekunqandeni i-CAPTCHA ethulula ukhuseleko oluphakeme lwe-spam kunye ne-bot ngaphandle kokusebenzisa i-cookies, iqinisekisa ukugcina i-GDPR ngokwemigaqo yayo. Le yincundlela ekhululwe ngenjongo yomphakathi (fork) ye-ALTCHA Spam Protection plugin (v1)."

