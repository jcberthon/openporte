#: admin/options.php:66
#, php-format
msgid "OpenPorte Spam Protection for WordPress, plugin version %1$s, ALTCHA widget version %2$s"
msgstr "Protezione anti-spam OpenPorte per WordPress, versione del plugin %1$s, versione del widget ALTCHA %2$s"

#. translators: the placeholders are opening and closing tags for a link (<a> tag)
#: admin/options.php:77
msgid "Please rate OpenPorte on WordPress.org to help us get the word out."
msgstr "Per favore valuta OpenPorte su WordPress.org per aiutarci a farci conoscere."

#. translators: %1$s and %2$s are the opening and closing tags of a link to the ALTCHA project.
#: admin/options.php:90
#, php-format
msgid "Powered by the %1$sALTCHA%2$s proof-of-work open-source project."
msgstr "Alimentato dal progetto open-source %1$sALTCHA%2$s basato su proof-of-work."

#: admin/options.php:97
msgid "Star OpenPorte on GitHub!"
msgstr "Metti una stella a OpenPorte su GitHub!"

#. translators: the placeholders are opening and closing tags for bold
#: admin/options.php:111
#, php-format
msgid "Both modes run without any external paid service. %1$sSelf-hosted%2$s generates challenges via the WordPress REST API. %3$sCustom%4$s lets you point to your own ALTCHA-compatible backend."
msgstr "Entrambe le modalità funzionano senza servizi esterni a pagamento. %1$sSelf-hosted%2$s genera sfide tramite l'API REST di WordPress. %3$sPersonalizzato%4$s ti permette di puntare al tuo backend compatibile con ALTCHA."

#. translators: the placeholders are opening and closing tags for bold
#: admin/options.php:130
#, php-format
msgid "The Spam Filter acts on the classification returned by a %1$sCustom%2$s backend. It has no effect in %3$sSelf-hosted%4$s mode, which uses proof-of-work only."
msgstr "Il filtro anti-spam agisce sulla classificazione restituita da un backend %1$sPersonalizzato%2$s. Non ha effetto in modalità %3$sSelf-hosted%4$s, che utilizza solo la proof-of-work."

