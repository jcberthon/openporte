#. Plugin Name of the plugin
#: openporte.php
#: includes/admin.php:15
msgid "OpenPorte Spam Protection"
msgstr "OpenPorte Spam Protection"

#. Description of the plugin
#: openporte.php
msgid "OpenPorte is a free, open-source CAPTCHA alternative that offers robust spam and bot protection without using cookies, ensuring full GDPR compliance by design. A community-maintained fork of the ALTCHA Spam Protection plugin (v1)."
msgstr "OpenPorte is een gratis, open-source CAPTCHA-alternatief dat robuuste spam- en botbescherming biedt zonder cookies te gebruiken, waardoor het van nature volledig GDPR-compliant is. Een door de community onderhouden fork van de ALTCHA Spam Protection-plugin (v1)."

