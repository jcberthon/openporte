#. Plugin Name of the plugin
#: openporte.php includes/admin.php:15
msgid "OpenPorte Spam Protection"
msgstr "OpenPorte Spam Protection"

#. Description of the plugin
#: openporte.php
msgid ""
"OpenPorte is a free, open-source CAPTCHA alternative that offers robust spam "
"and bot protection without using cookies, ensuring full GDPR compliance by "
"design. A community-maintained fork of the ALTCHA Spam Protection plugin "
"(v1)."
msgstr ""
"OpenPorte ist eine kostenlose, Open-Source-CAPTCHA-Alternative, die robusten "
"Spam- und Bot-Schutz ohne Cookies bietet und so von Grund auf vollständig "
"DSGVO-konform ist. Ein von der Community gepflegter Fork des ALTCHA-Spam-"
"Schutz-Plugins (v1)."

